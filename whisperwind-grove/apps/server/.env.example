# ElevenLabs API key (keep real key in .env, never commit it)
ELEVENLABS_API_KEY=

# Optional model override (default used by server: eleven_multilingual_v2)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Voice IDs for each Spirit Sapling guardian
ELEVENLABS_VOICE_ID_DEER=
ELEVENLABS_VOICE_ID_FOX=
ELEVENLABS_VOICE_ID_KODAMA=
ELEVENLABS_VOICE_ID_MONONOKE=

# Optional guardian-specific emotion tuning
# stability and similarity should generally be between 0.0 and 1.0
ELEVENLABS_DEER_STABILITY=0.72
ELEVENLABS_DEER_SIMILARITY=0.68
ELEVENLABS_DEER_STYLE=0.08
ELEVENLABS_DEER_SPEAKER_BOOST=false

ELEVENLABS_FOX_STABILITY=0.46
ELEVENLABS_FOX_SIMILARITY=0.86
ELEVENLABS_FOX_STYLE=0.82
ELEVENLABS_FOX_SPEAKER_BOOST=true

ELEVENLABS_KODAMA_STABILITY=0.62
ELEVENLABS_KODAMA_SIMILARITY=0.74
ELEVENLABS_KODAMA_STYLE=0.38
ELEVENLABS_KODAMA_SPEAKER_BOOST=false

ELEVENLABS_MONONOKE_STABILITY=0.38
ELEVENLABS_MONONOKE_SIMILARITY=0.90
ELEVENLABS_MONONOKE_STYLE=0.95
ELEVENLABS_MONONOKE_SPEAKER_BOOST=true
